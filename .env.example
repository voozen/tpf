# Firebase (required for authentication)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Hotjar / Contentsquare (behavior analytics)
# Paste the full script URL from Hotjar → Install → Script (Contentsquare tag)
VITE_HOTJAR_SCRIPT_URL=
# Legacy: numeric Site ID + @hotjar/browser (optional, if not using script URL)
VITE_HOTJAR_SITE_ID=

# Google Analytics 4
VITE_GA_MEASUREMENT_ID=
